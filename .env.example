# Токен Telegram бота (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# ID администраторов (разделенные запятыми)
ADMIN_IDS=123456789,987654321

# Настройки времени для автоматических уведомлений
NOTIFICATION_MORNING_TIME=08:00
NOTIFICATION_EVENING_TIME=18:00

# Часовой пояс (по умолчанию Europe/Kaliningrad)
TIMEZONE=Europe/Kaliningrad

# Настройки базы данных
DB_PATH=data/personnel.db

# Настройки экспорта
EXPORT_PATH=exports/

# Настройки логирования
LOG_LEVEL=INFO
LOG_PATH=logs/

# Настройки уведомлений
ENABLE_NOTIFICATIONS=true
NOTIFICATION_INTERVAL_HOURS=4